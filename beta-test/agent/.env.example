# x402Guard Beta Test Configuration
# Copy this to .env and fill in the values

# Agent wallet private key (Base Sepolia, funded with testnet USDC + ETH)
# Generate: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
AGENT_PRIVATE_KEY=0x...

# x402Guard proxy URL (production)
PROXY_URL=https://x402guard-production.up.railway.app

# x402Guard management API key
MANAGEMENT_API_KEY=your-management-api-key

# Mock service URL (where the x402-protected service is deployed)
MOCK_SERVICE_URL=https://your-mock-service.vercel.app

# Service wallet address (receives payments at the mock service)
# This is the payTo address in payment requirements
SERVICE_WALLET_ADDRESS=0x...

# ===========================================
# x402Guard Environment Variables
# Copy this to .env and fill in your values
# ===========================================

# --- Rust Proxy ---
PROXY_HOST=0.0.0.0
PROXY_PORT=3402
RUST_LOG=info,x402_guard_proxy=debug

# --- Supabase ---
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- Upstash Redis ---
UPSTASH_REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_TOKEN=

# --- Docker Compose Overrides ---
# When running inside docker compose, use service names instead of localhost:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres
# UPSTASH_REDIS_URL=redis://redis:6379

# --- Chain RPCs ---
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
SOLANA_RPC_URL=https://api.devnet.solana.com

# --- Dashboard (Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_PROXY_URL=http://localhost:3402

{
  "name": "@x402guard/core",
  "version": "0.1.0",
  "description": "TypeScript SDK for x402Guard — non-custodial safety proxy for AI agents making x402 DeFi payments. Spend limits, contract whitelists, session keys, instant revoke.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DzikPasnik/x402Guard.git",
    "directory": "examples/core"
  },
  "homepage": "https://x402guard.dev/docs",
  "bugs": {
    "url": "https://github.com/DzikPasnik/x402Guard/issues"
  },
  "author": "DzikPasnik <dzikpasnik@gmail.com> (https://github.com/DzikPasnik)",
  "keywords": [
    "x402",
    "defi",
    "ai-agents",
    "guardrails",
    "spend-limits",
    "session-keys",
    "eip-7702",
    "usdc",
    "base",
    "solana",
    "proxy",
    "safety",
    "non-custodial",
    "autonomous-agents"
  ],
  "dependencies": {
    "pino": "^10.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
